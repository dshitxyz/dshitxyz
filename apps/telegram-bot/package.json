{
  "name": "@dshit/telegram-bot",
  "version": "0.1.0",
  "description": "Telegram bot for dshit.xyz - price alerts, meme submissions, order updates, governance",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "telegraf": "^4.14.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "vitest": "^0.34.0",
    "tsx": "^4.0.0"
  }
}
