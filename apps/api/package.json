{
  "name": "@dshitxyz/api",
  "version": "0.1.0",
  "private": true,
  "description": "dshit.xyz API server (Fastify + PostgreSQL)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.3",
    "drizzle-kit": "^0.20.8",
    "postgres": "^3.4.3"
  },
  "devDependencies": {
    "@dshitxyz/config": "workspace:*",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
