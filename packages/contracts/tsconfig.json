{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "hardhat"],
    "baseUrl": "."
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "contracts/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
