{
  "name": "@dshit/contracts",
  "version": "0.1.0",
  "description": "Smart contracts for dshit.xyz",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:watch": "hardhat watch test",
