{
  "name": "@dshitxyz/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Smart contracts for dshit.xyz token and governance",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol'",
    "format:check": "prettier --check 'contracts/**/*.sol'",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "verify": "hardhat verify",
    "clean": "rm -rf artifacts cache dist"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "chai": "^4.3.10",
    "ethers": "^6.10.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "typescript": "^5.3.3"
  }
}
