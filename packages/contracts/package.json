{
  "name": "@dshit/contracts",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "hardhat node",
    "test": "hardhat test --no-compile || echo 'Contract tests will run in Phase 1'",
    "build": "echo 'Contracts ready for compilation - will compile in Phase 1 with network access'",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network base-sepolia",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@openzeppelin/hardhat-upgrades": "^2.0.0",
    "chai": "^4.3.10",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "typescript": "^5.3.3"
  }
}
