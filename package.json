{
  "name": "dshitxyz",
  "version": "0.0.1",
  "private": true,
  "description": "DSHIT - Brutalist meme commerce platform on Base L2",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
